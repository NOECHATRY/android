<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vert_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choisissez votre offre"
                android:textColor="@color/texte_main"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"/>

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1,2"
                android:background="@color/vert_medium"
                android:padding="1dp">

                <!-- Header -->
                <TableRow android:background="@color/vert_light">
                    <View
                        android:layout_width="120dp"
                        android:layout_height="match_parent"
                        android:background="@color/vert_light"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center"
                        android:background="@color/vert_light">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Standard"
                            android:textStyle="bold"
                            android:textColor="@color/vert_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gratuit"
                            android:textSize="12sp"
                            android:textColor="@color/vert_dark"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center"
                        android:background="@color/vert_light">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Premium"
                            android:textStyle="bold"
                            android:textColor="@color/vert_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="9,90 € /mois"
                            android:textSize="12sp"
                            android:textColor="@color/vert_dark"/>
                    </LinearLayout>
                </TableRow>

                <!-- Section Proposer des services -->
                <TableRow android:background="@color/vert_light">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Proposer des services"
                        android:textStyle="bold"
                        android:textColor="@color/texte_main"/>
                    <View android:layout_span="2"/>
                </TableRow>
                <TableRow android:background="@color/white">
                    <TextView android:padding="12dp" android:text="- Paramétrage" android:textSize="13sp" android:textColor="@color/texte_main"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                </TableRow>
                <TableRow android:background="@color/white">
                    <TextView android:padding="12dp" android:text="- Périmètre d'intervention" android:textSize="13sp" android:textColor="@color/texte_main"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                </TableRow>
                <TableRow android:background="@color/white">
                    <TextView android:padding="12dp" android:text="- Notifications « Nouvelles demandes »" android:textSize="13sp" android:textColor="@color/texte_main"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                </TableRow>

                <!-- Section Répondre aux demandes -->
                <TableRow android:background="@color/vert_light">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Répondre aux demandes"
                        android:textStyle="bold"
                        android:textColor="@color/texte_main"/>
                    <View android:layout_span="2"/>
                </TableRow>
                <TableRow android:background="@color/white">
                    <TextView android:padding="12dp" android:text="- Location de matériel" android:textSize="13sp" android:textColor="@color/texte_main"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                </TableRow>
                <TableRow android:background="@color/white">
                    <TextView android:padding="12dp" android:text="- Prestation de service" android:textSize="13sp" android:textColor="@color/texte_main"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                </TableRow>

                <!-- Section Afficher sur le profil -->
                <TableRow android:background="@color/vert_light">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Afficher sur le profil"
                        android:textStyle="bold"
                        android:textColor="@color/texte_main"/>
                    <View android:layout_span="2"/>
                </TableRow>
                <TableRow android:background="@color/white">
                    <TextView android:padding="12dp" android:text="- Numéro de téléphone" android:textSize="13sp" android:textColor="@color/texte_main"/>
                    <TextView android:gravity="center" android:text="X" android:textColor="@color/rouge_main" android:textSize="18sp"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                </TableRow>
                <TableRow android:background="@color/white">
                    <TextView android:padding="12dp" android:text="- Photos des réalisations" android:textSize="13sp" android:textColor="@color/texte_main"/>
                    <TextView android:gravity="center" android:text="X" android:textColor="@color/rouge_main" android:textSize="18sp"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                </TableRow>

                <!-- Section Assistance -->
                <TableRow android:background="@color/vert_light">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Assistance"
                        android:textStyle="bold"
                        android:textColor="@color/texte_main"/>
                    <View android:layout_span="2"/>
                </TableRow>
                <TableRow android:background="@color/white">
                    <TextView android:padding="12dp" android:text="- Accompagnement prioritaire" android:textSize="13sp" android:textColor="@color/texte_main"/>
                    <TextView android:gravity="center" android:text="X" android:textColor="@color/rouge_main" android:textSize="18sp"/>
                    <TextView android:gravity="center" android:text="✓" android:textColor="@color/vert_medium" android:textSize="18sp"/>
                </TableRow>
            </TableLayout>

            <Button
                android:id="@+id/btn_choisir_premium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Passer au Premium"
                android:backgroundTint="@color/vert_dark"
                android:padding="14dp"
                app:cornerRadius="8dp"
                android:textAllCaps="false"/>

            <Button
                android:id="@+id/btn_continuer_gratuit"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Continuer avec la version gratuite"
                android:textColor="@color/gris_main"
                android:textAllCaps="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>