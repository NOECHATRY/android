<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_detail_demande_titre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Titre de la demande"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_detail_demande_categorie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="#E3F2FD"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="Catégorie"
        android:textColor="#1565C0"
        android:textSize="12sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Description :"
        android:textColor="#333333"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_detail_demande_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Détails de la demande..."
        android:textColor="#666666" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Budget : "
            android:textColor="#333333"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_detail_demande_budget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 crédits"
            android:textColor="#000000" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statut : "
            android:textColor="#333333"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_detail_demande_statut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="En attente"
            android:textColor="#1565C0" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Réponse de l'offreur :"
        android:textColor="#333333"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_detail_demande_reponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Aucune réponse pour le moment."
        android:textColor="#666666"
        android:textStyle="italic" />

</LinearLayout>