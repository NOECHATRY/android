<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_detail_demande_titre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Titre de la demande"
        android:textColor="@color/texte_main"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_detail_demande_categorie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@color/vert_light"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="Catégorie"
        android:textColor="@color/vert_dark"
        android:textSize="12sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Description :"
        android:textColor="@color/texte_main"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_detail_demande_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Détails de la demande..."
        android:textColor="@color/gris_main" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Budget : "
            android:textColor="@color/texte_main"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_detail_demande_budget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 crédits"
            android:textColor="@color/vert_dark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statut : "
            android:textColor="@color/texte_main"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_detail_demande_statut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="En attente"
            android:textColor="@color/vert_medium" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_label_reponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Réponse de l'offreur :"
        android:textColor="@color/texte_main"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_detail_demande_reponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Aucune réponse pour le moment."
        android:textColor="@color/gris_main"
        android:textStyle="italic" />

    <!-- NOUVEAU BOUTON D'ACTION DANS LE LAYOUT -->
    <Button
        android:id="@+id/btn_dialog_accepter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/vert_dark"
        android:text="Accepter la mission"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:visibility="gone" />

</LinearLayout>